#: loop.php:3
msgid "Installments"
msgstr "Δόσεις"

# @ alphabank
msgid "This id (Merchant ID) is provided by the Alpha Bank."
msgstr "Αυτό το αναγνωριστικό (Merchant ID) παρέχεται από την Alpha Bank."

# @ alphabank
msgid "Pay securely with credit, debit and prepaid cards of Visa, MasterCard, Maestro, American Express, Diners and Discover through the electronic payment platform \"Alpha e-Commerce\" of Alpha Bank."
msgstr "Ασφαλές πληρωμές με πιστωτική, χρεωστική και προπληρωμένη κάρτα των Visa, MasterCard, Maestro, American Express, Diners και Discover μέσω της πλατφόρμας ηλεκτρονικών πληρωμών \"Alpha  e-Commerce\" της Alpha Bank."

# @ alphabank
msgid "Shared secret key"
msgstr "Μυστικό κλειδί"

# @ alphabank
msgid "Given to Merchant by Alpha Bank."
msgstr "Παρέχεται από την Alpha Bank."

# @ alphabank
msgid "Select combination or max. installments"
msgstr "Επιλέξτε συνδυασμό ή την μέγιστη Δόσεις"

# @ alphabank
msgid "Select Page"
msgstr "Επιλέξτε Σελίδα"

# @ alphabank
msgid "Returning Page on Error"
msgstr "Σελίδα αποτυχίας"

# @ alphabank
msgid "Select the failure page."
msgstr "Επιλέξτε τη σελίδα αποτυχίας."

# @ alphabank
msgid "If you like our <strong>plugin</strong>, please leave us a rating."
msgstr "Αν σας αρέσει το <strong>plugin</strong> μας, παρακαλώ αφήστε μας μια αξιολόγηση."

# @ alphabank
msgid "Thank you for your order, please continue payment."
msgstr "Σας ευχαριστούμε για την παραγγελία σας, παρακαλούμε συνεχίστε με την πληρωμή."

# @ alphabank
msgid "Continue without installments"
msgstr "Συνεχίστε χωρίς δόσεις"

# @ alphabank
msgid "Preauthorization"
msgstr "Προέγκριση"

# @ alphabank
msgid "installments"
msgstr "δόσεις"

# @ alphabank
msgid "The Bank does not support installment fee's.<br>This installment fee is \"virtual\", you can charge your client whith an additional fee for using installments."
msgstr "Η Τράπεζα δεν υποστηρίζει τέλη δόσεων.<br>Αυτά τα τέλη είναι \"εικονικά\", μπορείτε να χρεώσετε τον πελάτη σας με επιπλέον τέλη για τη χρήση των δόσεων."

# @ alphabank
msgid "Enter a installment fee (%) calculated from the cart total."
msgstr "Καταχωρίστε ένα τέλος δόσης (%) που υπολογίζεται από το σύνολο του καλαθιού."

# @ alphabank
msgid "allow"
msgstr "επιτρέπονται"

# @ alphabank
msgid "in %"
msgstr "σε %"

# @ alphabank
msgid "Example"
msgstr "Παράδειγμα"

# @ alphabank
msgid "Total order"
msgstr "Συνολική παραγγελία"

# @ alphabank
msgid "Installment Fee"
msgstr "Χρέωση δόσης"

# @ alphabank
msgid "and so on... else, leave the field blank."
msgstr "και ούτω καθεξής ...ή, αφήστε το πεδίο κενό."

# @ alphabank
msgid "Custom Installments"
msgstr "Προσαρμοσμένες δόσεις"

# @ alphabank
msgid "Months"
msgstr "Μήνες"

# @ alphabank
msgid "Select the recurrence duration"
msgstr "Επιλέξτε την περίοδο μηνών"

# @ alphabank
msgid "One time"
msgstr "Εφάπαξ πληρωμή"

# @ alphabank
